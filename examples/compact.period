-- Compact dot-and-parentheses syntax lives alongside the English forms.

import math, string.

show sqrt(16).
show upper("hello").

class Person:
    init with name, age:
        set this.name to name.
        set this.age to age.

    define greet with greeting:
        show greeting + ", " + this.name + "!".

let ada be new Person("Ada", 42).
ada.greet("Hello").
show ada.age.

-- Original English forms still work.
show the name of ada.
tell ada to greet with "Hi".
